{
  "name": "@basantbhat/agentburn",
  "version": "0.1.1",
  "description": "See exactly where your Claude Code tokens (and money) went.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentburn": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:compile": "tsc -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "cost",
    "ai",
    "cli",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saloni0106/agentburn.git"
  },
  "bugs": {
    "url": "https://github.com/Saloni0106/agentburn/issues"
  },
  "homepage": "https://github.com/Saloni0106/agentburn#readme"
}
